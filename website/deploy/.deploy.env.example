# Local deploy script settings.
#
# Copy to .deploy.env (gitignored) and fill in your server's address.
# Anything you export in your shell wins over what's set here, so this
# file just provides defaults for the common case.
#
# Required:
REMOTE_HOST=your.server.example.org

# Optional overrides — uncomment and edit if your server differs:
#REMOTE_USER=root
#SSH_KEY=$HOME/.ssh/id_rsa
#DEPLOY_DIR=/srv/chgk-model
#IMAGE_NAME=chgk-model
#IMAGE_TAG=latest
